# ==========================================
# 隐私 & 安全（绝对不能提交）
# ==========================================
.env
*.env
!*.env.example

# API Key、Token、密钥类文件
*-key.json
*.pem
secrets/

# ==========================================
# Python
# ==========================================
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg
.eggs/

# 虚拟环境
venv/
env/
.venv/
.conda/

# ==========================================
# IDE & 编辑器
# ==========================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ==========================================
# 日志 & 临时文件
# ==========================================
*.log
*.tmp
temp/
tmp/

# ==========================================
# 测试 & 调试（可能含敏感教学内容）
# ==========================================
playground/sample_docs/*
!playground/sample_docs/.gitkeep
playground/examples/*
!playground/examples/.gitkeep

# Jupyter
.ipynb_checkpoints/

# ==========================================
# 部署 & 运行时
# ==========================================
*.pid
*.sock

# ==========================================
# 项目特定
# ==========================================
# conda 环境锁文件（由 environment.yml 管理即可）
conda-lock.yml
