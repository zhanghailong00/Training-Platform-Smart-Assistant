# DeepSeek API 配置（主模型）
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Qwen API 配置（备用模型，主模型不可用时自动切换）
# FALLBACK_API_KEY=sk-your-qwen-key-here
# FALLBACK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# FALLBACK_MODEL=qwen-plus

# Qwen3.5-OCR 配置（图片文字识别，用于 OCR 试题识别功能）
# DASHSCOPE_API_KEY=sk-your-dashscope-key
# QWEN_OCR_BASE_URL=https://llm-j4lncwm5mk7pyl4v.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
# QWEN_OCR_MODEL=qwen3.5-ocr

# LLM 参数（可选，有默认值）
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=4096
# LLM_TOP_P=0.95

# 重试 & 超时（可选，有默认值）
# MAX_RETRIES=2
# LLM_REQUEST_TIMEOUT=60

# 文档处理（可选，有默认值）
# MAX_DOCUMENT_TOKENS=8000

# 服务配置（可选，有默认值）
# HOST=0.0.0.0
# PORT=7860

# 日志级别（可选，默认 INFO）
# LOG_LEVEL=INFO
